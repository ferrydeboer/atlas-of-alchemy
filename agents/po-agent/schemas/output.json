{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "POAgentOutput",
  "description": "Output schema for the PO Agent. One of three states: work_item, needs_clarification, or rejected.",
  "oneOf": [
    {
      "type": "object",
      "title": "WorkItem",
      "description": "Successfully refined requirements ready for Architect agent",
      "properties": {
        "status": { "const": "work_item" },
        "issue": {
          "type": "integer",
          "description": "Issue number this WorkItem was derived from"
        },
        "title": {
          "type": "string",
          "description": "Concise title for the change"
        },
        "changeRequest": {
          "type": "string",
          "description": "Clear description of what should change and why"
        },
        "acceptanceCriteria": {
          "type": "array",
          "description": "Testable criteria that define done",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[a-z0-9-]+$",
                "description": "Human-readable slug for traceability, e.g., 'retry-on-429'"
              },
              "criterion": {
                "type": "string",
                "description": "What must be true for this criterion to be met"
              },
              "status": {
                "type": "string",
                "enum": ["pending", "met", "failed"],
                "default": "pending",
                "description": "Current status (updated by Developer agent)"
              },
              "evidence": {
                "type": "string",
                "description": "Test name or commit reference proving status (set by Developer agent)"
              }
            },
            "required": ["id", "criterion", "status"]
          },
          "minItems": 1,
          "maxItems": 5
        },
        "scopeBoundary": {
          "type": "string",
          "description": "Explicit statement of what is in scope"
        },
        "affectedAreas": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Parts of the codebase likely to be affected"
        },
        "outOfScope": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Explicitly excluded items to prevent scope creep"
        },
        "decisionLog": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "decision": { "type": "string" },
              "rationale": { "type": "string" }
            },
            "required": ["decision", "rationale"]
          },
          "description": "Key decisions made during refinement with rationale"
        }
      },
      "required": ["status", "issue", "title", "changeRequest", "acceptanceCriteria", "scopeBoundary", "decisionLog"]
    },
    {
      "type": "object",
      "title": "NeedsClarification",
      "description": "Insufficient information to produce WorkItem, questions needed",
      "properties": {
        "status": { "const": "needs_clarification" },
        "issue": {
          "type": "integer",
          "description": "Issue number being processed"
        },
        "questions": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Questions to ask the requester",
          "minItems": 1,
          "maxItems": 3
        },
        "turnCount": {
          "type": "integer",
          "description": "Current turn number"
        },
        "context": {
          "type": "string",
          "description": "Brief explanation of why clarification is needed"
        }
      },
      "required": ["status", "issue", "questions", "turnCount"]
    },
    {
      "type": "object",
      "title": "Rejected",
      "description": "Request cannot be processed as a single WorkItem",
      "properties": {
        "status": { "const": "rejected" },
        "issue": {
          "type": "integer",
          "description": "Issue number being rejected"
        },
        "reason": {
          "type": "string",
          "description": "Why the request was rejected"
        },
        "suggestion": {
          "type": "string",
          "description": "How the requester could split or reformulate the request"
        }
      },
      "required": ["status", "issue", "reason"]
    }
  ]
}